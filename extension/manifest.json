{
  "manifest_version": 3,
  "name": "Predictive Maintenance Demo Bridge",
  "version": "0.1.0",
  "description": "Send page title, URL and selected text to the Electron predictive maintenance demo.",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": ["http://127.0.0.1:17654/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
